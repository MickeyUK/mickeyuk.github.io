{
    "files.associations": {
        "*.html": "jekyll"
    },
    "files.exclude": {
        "**/.git": true,
        "**/.svn": true,
        "**/.hg": true,
        "**/CVS": true,
        "**/.DS_Store": true,
        "**/.htaccess": true,
        "**/favicon-16x16.png": true,
        "**/favicon-32x32.png": true,
        "**/favicon-96x96.png": true,
